{
    "deny": [
        "rm", "rmdir", "shred", "dd",
        "sudo", "su", "doas",
        "chmod", "chown", "chgrp",
        "mount", "umount", "mkfs", "fdisk",
        "apt", "apt-get", "yum", "dnf", "brew",
        "kill", "killall", "pkill", "shutdown", "reboot", "systemctl",
        "nc", "ncat",
        "eval", "exec"
    ]
